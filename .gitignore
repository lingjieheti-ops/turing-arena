# Dependencies
node_modules/
.pnpm-store/

# Env / secrets — NEVER commit real keys
.env
.env.*
!.env.example
!.env.local.example

# Foundry (lib/ is committed as git submodules — forge-std + OpenZeppelin v5.1.0)
contracts/out/
contracts/cache/
contracts/broadcast/

# Builds
dist/
build/
.next/
out/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Runtime artifacts
agent/.state/
agent/*.local.json

# Keeper durable state IS committed (public reveal preimages + agent ids, no key).
# Keep this un-ignored even if broader rules above would match it.
!keeper-state/
!keeper-state/**

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
